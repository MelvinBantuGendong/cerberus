# env example, baca kalau bingung

# gateway port.
CERBERUS_LISTEN=:8080

# upstream URL, ini contoh punya open router
CERBERUS_UPSTREAM=https://openrouter.ai/api/v1

# api versioning dll
CERBERUS_INCOMING_PREFIX=/v1

# upstream key, dipakai ganti Authorization client sebelum diteruskan
CERBERUS_UPSTREAM_KEY=
OPENROUTER_API_KEY=

# cerberus key bootstrap, comma-separated. kosong = auth mati.
# setelah boot, key dikelola lewat admin API (POST/DELETE /admin/keys)
CERBERUS_API_KEYS=

# max ukuran body inbound (bytes) sebelum discan. default 4 MiB
CERBERUS_MAX_BODY_BYTES=4194304

# scan response: off (passthrough) | buffer (store-and-forward, default) | stream (hold-back window, live)
CERBERUS_OUTBOUND_MODE=buffer

# admin API token. kosong = admin API mati. protects /admin/
CERBERUS_ADMIN_TOKEN=

# file JSON tempat runtime state (keys + settings) disimpan. kosong = in-memory (hilang saat restart)
CERBERUS_STATE_PATH=

